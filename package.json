{
  "name": "hackathon-platform",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Hackathon monorepo – pnpm workspace + Docker",
  "scripts": {
    "dev": "docker compose up --build -d postgres n8n python-api && pnpm run dev:local",
    "dev:local": "pnpm run --parallel --filter hackathon-frontend --filter hackathon-backend dev",
    "dev:frontend": "pnpm --filter hackathon-frontend dev",
    "dev:backend": "pnpm --filter hackathon-backend dev",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:nuke": "docker compose down -v"
  },
  "packageManager": "pnpm@10.7.0+sha512.6b865ad4b62a1d9842b61d674a393903b871d9244954f652b8842c2b553c72176b278f64c463e52d40fff8aba385c235c8c9ecf5cc7de4fd78b8bb6d49633ab6"
}