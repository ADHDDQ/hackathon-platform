# ─── Postgres ────────────────────────────────────────────────
POSTGRES_USER=hackathon
POSTGRES_PASSWORD=hackathon_secret
POSTGRES_DB=hackathon_db
POSTGRES_PORT=5432

# ─── Backend (Express) ──────────────────────────────────────
BACKEND_PORT=4000
DATABASE_URL=postgresql://hackathon:hackathon_secret@postgres:5432/hackathon_db

# ─── Frontend (Vite React) ──────────────────────────────────
VITE_BACKEND_URL=http://localhost:4000

# ─── Python API (FastAPI) ───────────────────────────────────
PYTHON_API_PORT=8000
PYTHON_DATABASE_URL=postgresql://hackathon:hackathon_secret@postgres:5432/hackathon_db

# ─── n8n ────────────────────────────────────────────────────
N8N_PORT=5678
# n8n uses the same Postgres instance for its own metadata
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=hackathon_db
DB_POSTGRESDB_USER=hackathon
DB_POSTGRESDB_PASSWORD=hackathon_secret
N8N_ENCRYPTION_KEY=super-secret-encryption-key-change-me
